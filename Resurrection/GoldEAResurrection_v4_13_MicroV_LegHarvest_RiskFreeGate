//-------------------- Helpers --------------------
double PipToPrice(){ if(_Digits==3||_Digits==5) return 10.0*_Point; return _Point; }

double SpreadPoints() { return (SymbolInfoDouble(_Symbol,SYMBOL_ASK)-SymbolInfoDouble(_Symbol,SYMBOL_BID))/_Point; }

int CountPositions(int dir) {
   int c=0;
   for(int i=PositionsTotal()-1;i>=0;i--) {
      if(!pos.SelectByIndex(i)) continue;
      if(pos.Symbol()!=_Symbol || (ulong)pos.Magic()!=InpMagic) continue;
      if(dir== 1 && pos.PositionType()==POSITION_TYPE_BUY)  c++;
      if(dir==-1 && pos.PositionType()==POSITION_TYPE_SELL) c++;
   }
   return c;
}

// Risk-Free Gate Logic
bool IsGateOpen(int dir) {
   if(CountPositions(dir) == 0) return true;
   for(int i=0; i<ArraySize(g_tickets); i++) {
      if(PositionSelectByTicket(g_tickets[i]) && g_tp1done[i]) return true;
   }
   return false;
}

//-------------------- Entries --------------------
bool OpenBuy(double sl, double tp2, double structProtected, string &err) {
   if(CountPositions(-1) > 0) { err="Opposite positions exist"; return false; }
   if(CountPositions(1) >= InpMaxStackPerDir) { err="Stack limit reached"; return false; }
   if(!IsGateOpen(1)) { err="Risk-Free Gate Locked"; return false; }

   trade.SetExpertMagicNumber(InpMagic);
   double price=SymbolInfoDouble(_Symbol,SYMBOL_ASK);
   bool ok=trade.Buy(InpFixedLot,_Symbol,price,sl,tp2,"GoldEAResurrection v4.13 BUY");
   if(ok) {
      g_lastTradeTime=TimeCurrent();
      TrackNewTicket(trade.ResultOrder(), false, 0);
   }
   return ok;
}

bool OpenSell(double sl, double tp2, double structProtected, string &err) {
   if(CountPositions(1) > 0) { err="Opposite positions exist"; return false; }
   if(CountPositions(-1) >= InpMaxStackPerDir) { err="Stack limit reached"; return false; }
   if(!IsGateOpen(-1)) { err="Risk-Free Gate Locked"; return false; }

   trade.SetExpertMagicNumber(InpMagic);
   double price=SymbolInfoDouble(_Symbol,SYMBOL_BID);
   bool ok=trade.Sell(InpFixedLot,_Symbol,price,sl,tp2,"GoldEAResurrection v4.13 SELL");
   if(ok) {
      g_lastTradeTime=TimeCurrent();
      TrackNewTicket(trade.ResultOrder(), false, 0);
   }
   return ok;
}

void TrackNewTicket(ulong tk, bool tp1, double peak) {
   int n=ArraySize(g_tickets);
   ArrayResize(g_tickets,n+1); ArrayResize(g_tp1done,n+1); ArrayResize(g_peakProfit,n+1);
   g_tickets[n]=tk; g_tp1done[n]=tp1; g_peakProfit[n]=peak;
}

//-------------------- Core Loops --------------------
void OnTick() {
   if(IsPaused()) {
      if(TimeCurrent() >= g_pauseUntil) g_pauseUntil=0;
      else return;
   }
   
   ManageProfitRules();
   
   // Check for new bar logic
   datetime t=iTime(_Symbol,PERIOD_M1,0);
   if(t != g_lastBarTime) {
      g_lastBarTime = t;
      UpdateLegStateOnNewBar();
      // Placeholder for Pattern Detection Logic...
   }
}

bool IsPaused() { return (TimeCurrent() < g_pauseUntil); }

void ManageProfitRules() {
   for(int i=PositionsTotal()-1; i>=0; i--) {
      if(!pos.SelectByIndex(i) || (ulong)pos.Magic()!=InpMagic) continue;
      // Partial close and SL move logic here...
      // If profit >= InpTP1Money, move SL to InpRiskFreeLockMoney
   }
}

void UpdateLegStateOnNewBar() {
   if(!InpEnableLegHarvesting) return;
   g_legBars++;
   if(g_legBars > InpLegMaxBars) g_legActive=false;
}

int OnInit() {
   Print("GoldEAResurrection v4.13 Initialized with Risk-Free Gate");
   return INIT_SUCCEEDED;
}

