tp1MultInput = input.float(1.0, "TP1 Risk:Reward", minval = 0.5, maxval = 5.0, step = 0.1, group = GRP_RISK, tooltip = "TP1 = Entry ± (SL distance × this).\nFirst partial profit target.\nRecommended: 1.0")
tp2MultInput = input.float(2.0, "TP2 Risk:Reward", minval = 1.0, maxval = 8.0, step = 0.1, group = GRP_RISK, tooltip = "TP2 = Entry ± (SL distance × this).\nSecond profit target.\nRecommended: 2.0")
tp3MultInput = input.float(3.0, "TP3 Risk:Reward", minval = 1.5, maxval = 12.0, step = 0.5, group = GRP_RISK, tooltip = "TP3 = Entry ± (SL distance × this).\nFinal target / runner.\nRecommended: 3.0")

useTrailInput = input.bool(true, "Enable Trailing Stop", group = GRP_RISK, tooltip = "After TP1 hit, trail SL to breakeven.\nAfter TP2 hit, trail SL to TP1 level.\nReduces drawdown on winning trades.")

